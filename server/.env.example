# Required: OpenAI API key (never commit real keys)
OPENAI_API_KEY=sk-...

# Optional
OPENAI_MODEL=gpt-4o-mini
PORT=3001

# Comma-separated origins for browser CORS (production). Dev uses Vite proxy.
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Requests per minute per IP (default 30)
# RATE_LIMIT_PER_MIN=30
